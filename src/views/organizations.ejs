<%- include('partials/header', { title }) %>

    <h1>
        <%= title %>
    </h1>

    <h2>Our Partner Organizations</h2>

    <p>
        We collaborate with organizations around the world that provide meaningful
        service opportunities. These organizations help volunteers make a positive
        impact in their communities.
    </p>

    <% if (organizations && organizations.length> 0) { %>
        <ul>
            <% organizations.forEach((org)=> { %>
                <li>
                    <a href="/organizations/<%= org.organization_id %>">
                        <%= org.name %>
                    </a>
                </li>
                <% }) %>
        </ul>
        <% } else { %>
            <p>No organizations found.</p>
            <% } %>

                <%- include('partials/footer') %>