<%- include("partials/header", { title }) %>

    <main class="container">
        <h1>Assign Categories</h1>
        <h2>
            <%= project.name %>
        </h2>

        <% if (errors && errors.length> 0) { %>
            <div class="message error-messages">
                <ul>
                    <% errors.forEach(error=> { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
            </div>
            <% } %>

                <form action="/projects/<%= project.project_id %>/categories" method="POST" class="form-card">
                    <fieldset>
                        <legend>Select Categories</legend>

                        <% categories.forEach(category=> { %>
                            <div class="form-group">
                                <label>
                                    <input type="checkbox" name="categoryIds" value="<%= category.category_id %>" <% if
                                        (assignedCategoryIds.includes(category.category_id)) { %> checked <% } %>
                                        >
                                        <%= category.name %>
                                </label>
                            </div>
                            <% }) %>
                    </fieldset>

                    <button type="submit" class="btn">Save Categories</button>
                </form>

                <p>
                    <a href="/projects/<%= project.project_id %>">Back to Project Details</a>
                </p>
    </main>

    <%- include("partials/footer") %>