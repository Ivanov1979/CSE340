<%- include("partials/header", { title }) %>

    <h1>
        <%= category.name %>
    </h1>

    <h2>Projects in this category</h2>

    <% if (projects && projects.length> 0) { %>
        <ul>
            <% projects.forEach((project)=> { %>
                <li>
                    <a href="/projects/<%= project.project_id %>">
                        <%= project.name %>
                    </a>
                </li>
                <% }) %>
        </ul>
        <% } else { %>
            <p>No projects found.</p>
            <% } %>

                <%- include("partials/footer") %>