<h1>Edit Organization</h1>

<form action="/organizations/edit/<%= organization.organization_id %>" method="POST">
    <label for="name">Name:</label>
    <input type="text" id="name" name="name" value="<%= organization.name %>" required>

    <label for="description">Description:</label>
    <textarea id="description" name="description" required><%= organization.description %></textarea>

    <label for="contact_email">Contact Email:</label>
    <input type="email" id="contact_email" name="contact_email" value="<%= organization.contact_email %>" required>

    <label for="logo_filename">Logo Filename:</label>
    <input type="text" id="logo_filename" name="logo_filename" value="<%= organization.logo_filename %>" required>

    <button type="submit">Update Organization</button>
</form>